# Wrap Supabase URLs in double quotes. If the password contains #, an unquoted line is truncated (dotenv treats # as a comment).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/lob?schema=public"
#
# Supabase (production / Vercel):
# - Runtime (Next.js): use a pooler URL in DATABASE_URL — Session/Shared pooler or Dedicated :6543 per Connect tab.
# - Migrations (`prisma migrate deploy` on Vercel): set MIGRATE_DATABASE_URL to the DIRECT Postgres URL
#   (Connect → "Direct connection" / URI, host db.<ref>.supabase.co port 5432). Poolers often break migrate deploy.
#   If you omit MIGRATE_DATABASE_URL, Prisma falls back to DATABASE_URL (must be direct-capable).
# URL-encode special characters in passwords (@ # : / ? etc.).
# IPv4: if direct host fails from Vercel, use Supabase "Session pooler" host from Connect; for migrate, prefer direct 5432.
# MIGRATE_DATABASE_URL="postgresql://postgres:YOUR_DB_PASSWORD@db.<project-ref>.supabase.co:5432/postgres"
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
CLERK_WEBHOOK_SIGNING_SECRET="whsec_..."
# Optional: on preview/staging only — new carrier onboarding is APPROVED immediately (skip admin queue).
# LOB_AUTO_APPROVE_CARRIERS="true"
# Optional: show a yellow "Demo / preview" banner for everyone (safe to expose; only toggles UI text).
# NEXT_PUBLIC_LOB_DEMO_MODE="true"
# Optional: preview/staging only — these Clerk emails are promoted to ADMIN on every sign-in (case-insensitive). Remove before production.
# LOB_AUTO_ADMIN_EMAILS="you@example.com, partner@example.com"
# (Legacy single email still works: LOB_AUTO_ADMIN_EMAIL="you@example.com")

# Optional: CAD offer → USD equivalent for fair-rate benchmarks (default 0.73 if unset).
# LOB_CAD_TO_USD_RATE="0.73"

# Rolling benchmark window for LaneRateObservation (posted rates in DB). Default 60.
# LOB_BENCHMARK_WINDOW_DAYS="60"

