# Wrap Supabase URLs in double quotes. If the password contains #, an unquoted line is truncated (dotenv treats # as a comment).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/lob?schema=public"
# Vercel: direct db.<project>.supabase.co often fails (IPv6). Use the Session pooler URL from Supabase Connect (*.pooler.supabase.com:5432) for DATABASE_URL there.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
CLERK_WEBHOOK_SIGNING_SECRET="whsec_..."
# Optional: on preview/staging only — new carrier onboarding is APPROVED immediately (skip admin queue).
# LOB_AUTO_APPROVE_CARRIERS="true"
# Optional: show a yellow "Demo / preview" banner for everyone (safe to expose; only toggles UI text).
# NEXT_PUBLIC_LOB_DEMO_MODE="true"
# Optional: preview/staging only — Clerk user's email (exact match, case-insensitive) is promoted to ADMIN on every sign-in. Remove before production.
# LOB_AUTO_ADMIN_EMAIL="you@example.com"

