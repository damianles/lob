# Wrap Supabase URLs in double quotes. If the password contains #, an unquoted line is truncated (dotenv treats # as a comment).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/lob?schema=public"
#
# Supabase (production / Vercel):
# CRITICAL: Do NOT use host db.<project>.supabase.co in DATABASE_URL on Vercel — use the pooler URI from Connect
# (hostname must contain pooler.supabase.com). Direct db.* host → "Can't reach database server" on serverless.
# - Runtime (Next.js): use a pooler URL in DATABASE_URL — Session pooler from Connect is the usual fix.
# - Migrations (`prisma migrate deploy` on Vercel): set MIGRATE_DATABASE_URL to the DIRECT Postgres URL
#   (Connect → "Direct connection" / URI, host db.<ref>.supabase.co port 5432). Poolers often break migrate deploy.
#   If you omit MIGRATE_DATABASE_URL, Prisma falls back to DATABASE_URL (must be direct-capable).
# URL-encode special characters in passwords (@ # : / ? etc.).
# IPv4: if direct host fails from Vercel, use Supabase "Session pooler" host from Connect; for migrate, prefer direct 5432.
# Session pooler has a low global connection cap (~15). This app defaults to DATABASE_POOL_MAX=1 when the host is
# pooler.supabase.com. Only raise this if Supabase increased your limit and you know the safe value.
# DATABASE_POOL_MAX="1"
# MIGRATE_DATABASE_URL="postgresql://postgres:YOUR_DB_PASSWORD@db.<project-ref>.supabase.co:5432/postgres"
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
CLERK_WEBHOOK_SIGNING_SECRET="whsec_..."
# Optional: on preview/staging only — new carrier onboarding is APPROVED immediately (skip admin queue).
# LOB_AUTO_APPROVE_CARRIERS="true"
# Optional: show a yellow "Demo / preview" banner for everyone (safe to expose; only toggles UI text).
# NEXT_PUBLIC_LOB_DEMO_MODE="true"
# Optional: preview/staging only — these Clerk emails are promoted to ADMIN on every sign-in (case-insensitive). Remove before production.
# LOB_AUTO_ADMIN_EMAILS="you@example.com, partner@example.com"
# (Legacy single email still works: LOB_AUTO_ADMIN_EMAIL="you@example.com")
# Optional: preview/staging only — lets those admin emails switch to seeded shipper/carrier personas (see /admin/test-lab).
# Requires npm run db:seed. Do not enable in production.
# LOB_ALLOW_ADMIN_PERSONA_SWITCH="true"

# Google Maps (shared key). Enable in Google Cloud for each product you use:
# - Directions API — /api/insights/route-planning
# - Places API — Autocomplete + Place Details — /api/places/* and post-load "Search place" fields
# GOOGLE_MAPS_API_KEY="..."

# Optional: U.S. EIA Open Data — official weekly national average retail No. 2 diesel (USD/gal). Free key: https://www.eia.gov/opendata/
# EIA_API_KEY="..."

# Optional: future weather sampling along routes (route-planning API messaging; wire forecasts when ready).
# OPENWEATHER_API_KEY="..."

# Optional: CAD offer → USD equivalent for fair-rate benchmarks (default 0.73 if unset).
# LOB_CAD_TO_USD_RATE="0.73"

# Max discount from rolling lane average (0.3 = cannot post more than 30% below the average; no upper cap).
# LOB_MAX_RATE_DISCOUNT_FROM_AVG=0.3
# Rolling benchmark window for LaneRateObservation (posted rates in DB). Default 60.
# LOB_BENCHMARK_WINDOW_DAYS="60"

# Minimum live observations in that window before DB averages override data/market-benchmarks.json (wholesaler base). Default 5.
# LOB_MIN_SAMPLES_FOR_DB_BENCHMARK="5"

